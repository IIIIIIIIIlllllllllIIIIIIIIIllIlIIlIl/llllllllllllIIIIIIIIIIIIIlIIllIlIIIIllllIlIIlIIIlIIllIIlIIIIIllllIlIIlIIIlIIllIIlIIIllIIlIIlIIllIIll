--treedeleter
local treesFolder = game.Workspace
        :WaitForChild("Map")
        :WaitForChild("CopeTrialsDirectory")
        :WaitForChild("Hunt")
        :WaitForChild("Parts")
        :WaitForChild("Trees")

    for _, tree in ipairs(treesFolder:GetChildren()) do
        
        -- Loop through everything inside each tree
        for _, obj in ipairs(tree:GetDescendants()) do
            
            -- Remove SurfaceAppearance (this is what your screenshot shows)
            if obj:IsA("SurfaceAppearance") then
                obj:Destroy()
            end

            -- Remove mesh IDs if any exist
            if obj:IsA("MeshPart") then
                obj.MeshId = ""
            elseif obj:IsA("SpecialMesh") then
                obj.MeshId = ""
            end
        end

        -- Change transparency of the "Part"
        local part = tree:FindFirstChild("Part")
        if part and part:IsA("BasePart") then
            part.Transparency = 0.5
        end
    end
end)
