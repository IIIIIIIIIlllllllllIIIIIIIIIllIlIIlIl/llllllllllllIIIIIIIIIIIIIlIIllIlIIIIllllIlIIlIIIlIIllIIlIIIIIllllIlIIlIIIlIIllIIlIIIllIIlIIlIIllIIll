-- Helpers
local function getRestockTime(dealer)
    local restockObj = dealer:FindFirstChild("RestockTime", true)
    if restockObj and restockObj:IsA("ValueBase") then return tostring(restockObj.Value).."s" end
    local attr = dealer:GetAttribute("RestockTime")
    if attr then return tostring(attr).."s" end
    return "Unknown"
end

local function scanDealer(dealer)
    local currentStocks = dealer:FindFirstChild("CurrentStocks")
    local foundItems = {}
    for _, itemName in ipairs(ItemsToCheck) do foundItems[itemName] = false end

    if currentStocks then
        for _, stock in ipairs(currentStocks:GetChildren()) do
            for _, itemName in ipairs(ItemsToCheck) do
                if stock.Name == itemName and stock.Value == 1 then
                    foundItems[itemName] = true
                end
            end
        end
    end

    return foundItems
end

local function highlightDealer(mainPart)
    if not mainPart then return end
    if mainPart:FindFirstChild("CopeHighlight") then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "CopeHighlight"
    highlight.FillColor = Color3.fromRGB(0,255,0)
    highlight.OutlineColor = Color3.fromRGB(255,255,0)
    highlight.FillTransparency = 0.3
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = mainPart
    highlight.Parent = mainPart
end

