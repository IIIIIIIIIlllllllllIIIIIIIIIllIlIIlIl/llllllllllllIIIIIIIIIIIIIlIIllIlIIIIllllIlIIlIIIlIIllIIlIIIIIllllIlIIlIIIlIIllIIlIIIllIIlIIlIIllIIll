-- Rows
local dealerRows = {}
local rowHeight = 25
local index = 0

for _, data in ipairs(DealerLocations) do
    local label = Instance.new("TextButton")
    label.Size = UDim2.new(0, dealerColumnWidth, 0, rowHeight)
    label.Position = UDim2.new(0, 0, 0, headerHeight + index*rowHeight)
    label.Text = data.name .. " (waiting)"
    label.BackgroundColor3 = Color3.fromRGB(60,60,60)
    label.TextColor3 = Color3.fromRGB(255,255,255)
    label.Parent = scrollFrame

    dealerRows[data.name] = {
        label = label,
        rowIndex = index,
        dealerInstance = nil,
        position = data.pos
    }

    index += 1
end

scrollFrame.CanvasSize = UDim2.new(0, dealerColumnWidth + #ItemsToCheck*cellWidth, 0, headerHeight + index*rowHeight)

-- UPDATE LOOP
while true do
    -- ✅ reset (fixes AF disappearing issue)
    for _, row in pairs(dealerRows) do
        row.dealerInstance = nil
    end

    -- match dealers
    for _, dealer in ipairs(Shopz:GetChildren()) do
        if dealer.Name == "Dealer" or dealer.Name == "ArmoryDealer" then
            local mainPart = dealer:FindFirstChild("MainPart")
            if mainPart then
                for _, row in pairs(dealerRows) do
                    if (mainPart.Position - row.position).Magnitude < 25 then
                        row.dealerInstance = dealer
                    end
                end
            end
        end
    end

    -- update GUI
    for name, row in pairs(dealerRows) do
        local foundItems = {}
        for _, itemName in ipairs(ItemsToCheck) do
            foundItems[itemName] = false
        end

        if row.dealerInstance then
            local dealer = row.dealerInstance
            foundItems = scanDealer(dealer)
            local restock = getRestockTime(dealer)
            row.label.Text = name .. " (" .. restock .. ")"
        else
            row.label.Text = name .. " (waiting)"
        end

        if row.itemCells then
            for _, cell in pairs(row.itemCells) do
                cell:Destroy()
            end
        end

        row.itemCells = {}

        for i, itemName in ipairs(ItemsToCheck) do
            local cell = Instance.new("TextLabel")
            cell.Size = UDim2.new(0, cellWidth, 0, rowHeight)
            cell.Position = UDim2.new(0, dealerColumnWidth + (i-1)*cellWidth, 0, headerHeight + row.rowIndex*rowHeight)

            if row.dealerInstance then
                cell.BackgroundColor3 = foundItems[itemName] and Color3.fromRGB(0,200,0) or Color3.fromRGB(150,0,0)
            else
                cell.BackgroundColor3 = Color3.fromRGB(80,80,80)
            end

            cell.Text = ""
            cell.Parent = scrollFrame
            row.itemCells[itemName] = cell
        end
    end

    task.wait(1)
end
