	local valLabel = Instance.new("TextLabel")
	valLabel.Parent = row
	valLabel.BackgroundTransparency = 1
	valLabel.Position = UDim2.new(0.6, 0, 0, 0)
	valLabel.Size = UDim2.new(0.4, -10, 0, 20)
	valLabel.Font = Enum.Font.Code
	valLabel.TextSize = 12
	valLabel.TextXAlignment = Enum.TextXAlignment.Right
	valLabel.TextColor3 = THEME.accent
	valLabel.Text = ""

	local trackFrame = Instance.new("Frame")
	trackFrame.Parent = row
	trackFrame.BackgroundColor3 = THEME.sliderBg
	trackFrame.BorderSizePixel = 0
	trackFrame.Position = UDim2.new(0, 10, 0, 26)
	trackFrame.Size = UDim2.new(1, -20, 0, 8)
	makeCorner(trackFrame, 4)

	local fill = Instance.new("Frame")
	fill.Parent = trackFrame
	fill.BackgroundColor3 = THEME.sliderFill
	fill.BorderSizePixel = 0
	fill.Size = UDim2.new(0, 0, 1, 0)
	makeCorner(fill, 4)

	local thumbBtn = Instance.new("TextButton")
	thumbBtn.Parent = trackFrame
	thumbBtn.BackgroundColor3 = Color3.new(1, 1, 1)
	thumbBtn.BorderSizePixel = 0
	thumbBtn.Size = UDim2.new(0, 14, 0, 14)
	thumbBtn.Position = UDim2.new(0, 0, 0.5, -7)
	thumbBtn.Text = ""
	thumbBtn.AutoButtonColor = false
	thumbBtn.ZIndex = 2
	makeCorner(thumbBtn, 7)

	local currentVal = default or min
	local sliding = false

	local function quantize(v)
		if step and step > 0 then
			v = math.floor(v / step + 0.5) * step
		end
		return math.clamp(v, min, max)
	end

	local function updateVisual()
		local t = (currentVal - min) / (max - min)
		fill.Size = UDim2.new(t, 0, 1, 0)
		thumbBtn.Position = UDim2.new(t, -7, 0.5, -7)
		valLabel.Text = fmt and string.format(fmt, currentVal) or tostring(currentVal)
	end

	local function setFromInput(inputX)
		local abs = trackFrame.AbsolutePosition.X
		local w = trackFrame.AbsoluteSize.X
		local t = math.clamp((inputX - abs) / w, 0, 1)
		currentVal = quantize(min + t * (max - min))
		updateVisual()
		if onChange then onChange(currentVal) end
	end

	thumbBtn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			sliding = true
		end
	end)

	trackFrame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			sliding = true
			setFromInput(input.Position.X)
		end
	end)

	connections["slider_move_" .. name] = UIS.InputChanged:Connect(function(input)
		if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setFromInput(input.Position.X)
		end
	end)

	connections["slider_end_" .. name] = UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			sliding = false
		end
	end)

	updateVisual()

	local api = {}
	function api.get() return currentVal end
	function api.set(v)
		currentVal = quantize(v)
		updateVisual()
		if onChange then onChange(currentVal) end
	end
	return api
end

