local function addSlider(name, min, max, default, step, fmt, onChange)
	local row = Instance.new("Frame")
	row.Parent = content
	row.BackgroundColor3 = THEME.surface
	row.BorderSizePixel = 0
	row.Size = UDim2.new(1, 0, 0, 44)
