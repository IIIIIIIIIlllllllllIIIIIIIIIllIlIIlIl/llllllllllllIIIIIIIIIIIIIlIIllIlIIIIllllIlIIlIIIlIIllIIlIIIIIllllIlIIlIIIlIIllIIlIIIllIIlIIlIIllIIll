local function masterCleanup()
	for _, conn in connections do
		if typeof(conn) == "RBXScriptConnection" then conn:Disconnect() end
	end
	for _, conn in floatConns do
		if typeof(conn) == "RBXScriptConnection" then conn:Disconnect() end
	end
	if floatPart and floatPart.Parent then floatPart:Destroy() end
	for _, obj in drawObjects do pcall(function() obj:Remove() end) end
	for _, hl in espHighlights do pcall(function() hl:Destroy() end) end
	for _, inst in memHighlights do if inst and inst.Parent then inst:Destroy() end end
	if gui and gui.Parent then gui:Destroy() end
	table.clear(connections)
	table.clear(floatConns)
	table.clear(drawObjects)
	table.clear(espHighlights)
	table.clear(memHighlights)
	table.clear(pageEsps)
	table.clear(guiElements)
	floating = false
	floatPart = nil
	pagesEspEnabled = false
	copemanEspEnabled = false
	staminaEnabled = false
	if staminaHooked then
		pcall(unhookStamina)
	end
	if tpWalkConn then tpWalkConn:Disconnect() tpWalkConn = nil end
	tpWalkEnabled = false
	memSolverActive = false
	copemanEsp = nil
	pcall(function() RunService:UnbindFromRenderStep("CT_HUNT_1") end)
	pcall(function() RunService:UnbindFromRenderStep("CT_HUNT_2") end)
	if noStaticConn then noStaticConn:Disconnect() noStaticConn = nil end
	if fullbrightConn then fullbrightConn:Disconnect() fullbrightConn = nil end
	huntInvincible = false
	noStaticEnabled = false
	fullbrightEnabled = false
	_G._CT = nil
end
_G._CT = masterCleanup

