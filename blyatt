local function initHuntEsp()
	if huntInited then return true end
	local copeDir = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("CopeTrialsDirectory")
	if not copeDir then return false end
	local huntModel = copeDir:FindFirstChild("Hunt")
	if not huntModel then return false end
	local scriptables = huntModel:FindFirstChild("Scriptables")
	if scriptables then
		pageFolder = scriptables:FindFirstChild("Pages2") or scriptables:FindFirstChild("Pages")
	end
	if not pageFolder then return false end

	for _, child in workspace:GetDescendants() do
		if child.Name == "Copeman" and child:IsA("Model") and child:FindFirstChild("RootPart") then
			copemanModel = child
			break
		end
	end

	for _, page in pageFolder:GetChildren() do
		if page.Name == "PagePart" then
			table.insert(pageEsps, {
				part = page,
				highlight = createEspHighlight(page, THEME.accent, 0.65, 0.2),
				nameText = createDrawText(Color3.new(1, 1, 1)),
				infoText = createDrawText(Color3.fromRGB(200, 200, 200)),
			})
		end
	end

	if copemanModel then
		copemanEsp = {
			model = copemanModel,
			highlight = createEspHighlight(copemanModel, THEME.red, 0.4, 0),
			nameText = createDrawText(Color3.new(1, 1, 1)),
			infoText = createDrawText(Color3.fromRGB(200, 200, 200)),
		}
	end

	connections.pageRemoved = pageFolder.ChildRemoved:Connect(function(child)
		for _, esp in pageEsps do
			if esp.part == child then
				esp.nameText.Visible = false
				esp.infoText.Visible = false
				if esp.highlight then esp.highlight.Enabled = false end
				break
			end
		end
	end)

	if not copemanModel then
		connections.copemanWatch = workspace.DescendantAdded:Connect(function(desc)
			if desc.Name == "Copeman" and desc:IsA("Model") then
				task.defer(function()
					local root = desc:WaitForChild("RootPart", 5)
					if root then
						copemanModel = desc
						copemanEsp = {
							model = desc,
							highlight = createEspHighlight(desc, THEME.red, 0.4, 0),
							nameText = createDrawText(Color3.new(1, 1, 1)),
							infoText = createDrawText(Color3.fromRGB(200, 200, 200)),
						}
					end
				end)
			end
		end)
	end

	huntInited = true
	return true
end

local function updateHuntEsp()
	local cam = CurrentCamera
	local camPos = cam.CFrame.Position
	local character = LocalPlayer.Character
	local charPos = character and character:FindFirstChild("HumanoidRootPart") and character.HumanoidRootPart.Position or camPos
	local ppsFactor = cam.ViewportSize.Y * 0.5 / mathTan(mathRad(cam.FieldOfView * 0.5))
	local V2 = Vector2.new
	local MAX_DIST = 2000

	for _, esp in pageEsps do
		local part = esp.part
		if not pagesEspEnabled or not part or not part.Parent then
			esp.nameText.Visible = false
			esp.infoText.Visible = false
			if esp.highlight then esp.highlight.Enabled = false end
			continue
		end

		local prompt = part:FindFirstChild("ProximityPos") and part.ProximityPos:FindFirstChild("ProximityPrompt")
		if prompt and not prompt.Enabled then
			esp.nameText.Visible = false
			esp.infoText.Visible = false
			if esp.highlight then esp.highlight.Enabled = false end
			continue
		end

		if part.Transparency >= 0.9 then
			esp.nameText.Visible = false
			esp.infoText.Visible = false
			if esp.highlight then esp.highlight.Enabled = false end
			continue
		end

		local dist = (part.Position - charPos).Magnitude
		if dist > MAX_DIST then
			esp.nameText.Visible = false
			esp.infoText.Visible = false
			if esp.highlight then esp.highlight.Enabled = false end
			continue
		end

		if esp.highlight then esp.highlight.Enabled = true end
		local screenPos, onScreen = cam:WorldToViewportPoint(part.Position)
		if onScreen then
			local sx = screenPos.X
			local pps = ppsFactor / screenPos.Z
			esp.nameText.Text = "PAGE"
			esp.nameText.Position = V2(sx, screenPos.Y - 1.5 * pps - 15)
			esp.nameText.Visible = true
			esp.infoText.Text = math.floor(dist) .. "s"
			esp.infoText.Position = V2(sx, screenPos.Y + 1.5 * pps + 2)
			esp.infoText.Visible = true
		else
			esp.nameText.Visible = false
			esp.infoText.Visible = false
		end
	end

	if copemanEsp then
		local root = copemanEsp.model and copemanEsp.model:FindFirstChild("RootPart")
		if not copemanEspEnabled or not root or not root.Parent or root.Position.Y < -100 then
			copemanEsp.nameText.Visible = false
			copemanEsp.infoText.Visible = false
			if copemanEsp.highlight then copemanEsp.highlight.Enabled = false end
		else
			local dist = (root.Position - charPos).Magnitude
			if copemanEsp.highlight then copemanEsp.highlight.Enabled = true end
			local screenPos, onScreen = cam:WorldToViewportPoint(root.Position)
			if onScreen and dist < MAX_DIST then
				local sx = screenPos.X
				local pps = ppsFactor / screenPos.Z
				copemanEsp.nameText.Text = "COPEMAN"
				copemanEsp.nameText.Position = V2(sx, screenPos.Y - 3 * pps - 15)
				copemanEsp.nameText.Visible = true
				copemanEsp.infoText.Text = math.floor(dist) .. "s"
				copemanEsp.infoText.Position = V2(sx, screenPos.Y + 3 * pps + 2)
				copemanEsp.infoText.Visible = true
			else
				copemanEsp.nameText.Visible = false
				copemanEsp.infoText.Visible = false
			end
		end
	end
end

