local function hookStamina()
	if staminaHooked then return true end
	local gameG = getrenv()._G
	if not gameG.S_Check or not gameG.S_Take then return false end
	local alwaysTrue = newcclosure(function() return true end)
	local noDrain = newcclosure(function() return 100 end)
	local ok1, realSTake = pcall(debug.getupvalue, gameG.S_Take, 2)
	local ok2, realSCheck = pcall(debug.getupvalue, gameG.S_Check, 2)
	if ok1 and type(realSTake) == "function" then
		origRealSTake = hookfunction(realSTake, noDrain)
	end
	if ok2 and type(realSCheck) == "function" then
		origRealSCheck = hookfunction(realSCheck, alwaysTrue)
	end
	origSCheck = hookfunction(gameG.S_Check, alwaysTrue)
	origSTake = hookfunction(gameG.S_Take, noDrain)
	staminaHooked = true
	return true
end

local function unhookStamina()
	if not staminaHooked then return end
	local gameG = getrenv()._G
	if origRealSCheck then
		local ok, cur = pcall(debug.getupvalue, gameG.S_Check, 2)
		if ok and type(cur) == "function" then pcall(hookfunction, cur, origRealSCheck) end
	end
	if origRealSTake then
		local ok, cur = pcall(debug.getupvalue, gameG.S_Take, 2)
		if ok and type(cur) == "function" then pcall(hookfunction, cur, origRealSTake) end
	end
	if origSCheck and gameG.S_Check then pcall(hookfunction, gameG.S_Check, origSCheck) end
	if origSTake and gameG.S_Take then pcall(hookfunction, gameG.S_Take, origSTake) end
	staminaHooked = false
	origRealSTake = nil
	origRealSCheck = nil
end

local function startTpWalk()
	if tpWalkConn then tpWalkConn:Disconnect() end
	local character = LocalPlayer.Character
	local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
	if not character or not humanoid then return end
	tpWalkConn = RunService.Heartbeat:Connect(function(delta)
		if not tpWalkEnabled then return end
		local char = LocalPlayer.Character
		local hum = char and char:FindFirstChildWhichIsA("Humanoid")
		if not char or not hum or not hum.Parent then
			return
		end
		if hum.MoveDirection.Magnitude > 0 then
			char:TranslateBy(hum.MoveDirection * tpWalkSpeed * delta * 10)
		end
	end)
end

local function stopTpWalk()
	if tpWalkConn then tpWalkConn:Disconnect() tpWalkConn = nil end
end

local function stopFloat()
	floating = false
	floatKeysHeld.E = false
	floatKeysHeld.Q = false
	if floatPart and floatPart.Parent then floatPart:Destroy() end
	floatPart = nil
	for _, conn in floatConns do
		if typeof(conn) == "RBXScriptConnection" then conn:Disconnect() end
	end
	table.clear(floatConns)
end

local function startFloat()
	if floating then return end
	floating = true
	floatKeysHeld.E = false
	floatKeysHeld.Q = false
	local pchar = LocalPlayer.Character
	if not pchar then floating = false return end
	local root = getRoot()
	if not root then floating = false return end

	floatY = root.Position.Y - 3.1

	floatPart = Instance.new("Part")
	floatPart.Name = "_ct_float"
	floatPart.Parent = pchar
	floatPart.Transparency = 1
	floatPart.Size = Vector3.new(6, 0.2, 6)
	floatPart.Anchored = true
	floatPart.CanCollide = true
	floatPart.CFrame = CFrame.new(root.Position.X, floatY, root.Position.Z)

	floatConns.keyDown = UIS.InputBegan:Connect(function(input, processed)
		if processed then return end
		if input.KeyCode == Enum.KeyCode.E then floatKeysHeld.E = true
		elseif input.KeyCode == Enum.KeyCode.Q then floatKeysHeld.Q = true end
	end)

	floatConns.keyUp = UIS.InputEnded:Connect(function(input)
		if input.KeyCode == Enum.KeyCode.E then floatKeysHeld.E = false
		elseif input.KeyCode == Enum.KeyCode.Q then floatKeysHeld.Q = false end
	end)

	local hum = pchar:FindFirstChildWhichIsA("Humanoid")
	if hum then
		floatConns.died = hum.Died:Connect(function() stopFloat() end)
	end

	floatConns.loop = RunService.Heartbeat:Connect(function(dt)
		local root2 = getRoot()
		if not floatPart or not floatPart.Parent or not root2 then
			stopFloat()
			return
		end
		if floatKeysHeld.E then floatY += floatSpeed * dt end
		if floatKeysHeld.Q then floatY -= floatSpeed * dt end
		floatPart.CFrame = CFrame.new(root2.Position.X, floatY, root2.Position.Z)
	end)
end

