local function getSymbolName(parent)
	for _, child in parent:GetChildren() do
		if child:IsA("MeshPart") and string.find(child.Name, "Symbol_") then
			return child.Name
		end
	end
	return nil
end

local function getModelPosition(model)
	local primary = model:FindFirstChild("Part") or model:FindFirstChildWhichIsA("BasePart")
	if primary then return primary.Position end
	return Vector3.zero
end

local function clearMemSolver()
	for _, inst in memHighlights do
		if inst and inst.Parent then inst:Destroy() end
	end
	table.clear(memHighlights)
	memSolverActive = false
end

local function runMemSolver()
	clearMemSolver()
	local copeDir = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("CopeTrialsDirectory")
	if not copeDir then warn("[Multy Trials] Memory Solver: CopeTrialsDirectory not found") return end

	local stagesFolder
	for _, desc in copeDir:GetDescendants() do
		if desc.Name == "Stages" and desc:IsA("Folder") then stagesFolder = desc break end
	end
	if not stagesFolder then warn("[Multy Trials] Memory Solver: Stages folder not found") return end

	local totalHighlighted = 0
	local function addMemHighlight(adornee, color, fillTransparency)
		local h = Instance.new("Highlight")
		h.FillColor = color
		h.FillTransparency = fillTransparency or 0.35
		h.OutlineColor = Color3.new(1, 1, 1)
		h.OutlineTransparency = 0.3
		h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		h.Adornee = adornee
		h.Parent = CoreGui
		table.insert(memHighlights, h)
	end

	for _, stage in stagesFolder:GetChildren() do
		if not stage:IsA("Folder") then continue end
		local symbolsFolder = stage:FindFirstChild("Symbols")
		local rowsFolder = stage:FindFirstChild("Rows")

		if symbolsFolder and rowsFolder then
			local answerKey = {}
			for _, symbolModel in symbolsFolder:GetChildren() do
				local idx = tonumber(symbolModel.Name)
				if not idx then continue end
				local part = symbolModel:FindFirstChild("Part")
				if not part then continue end
				local name = getSymbolName(part)
				if name then answerKey[idx] = name end
			end

			for _, row in rowsFolder:GetChildren() do
				local rowIdx = tonumber(string.match(row.Name, "(%d+)$"))
				if not rowIdx or not answerKey[rowIdx] then continue end
				for _, platform in row:GetChildren() do
					if not platform:IsA("Model") then continue end
					local pos = getModelPosition(platform)
					if pos.Magnitude < MIN_DISTANCE_FROM_ORIGIN then continue end
					if getSymbolName(platform) == answerKey[rowIdx] then
						addMemHighlight(platform, PASTEL_YELLOW, 0.35)
						totalHighlighted += 1
					end
				end
			end
		end

		local exit = stage:FindFirstChild("Exit")
		if exit and exit:IsA("BasePart") and exit.Position.Magnitude >= MIN_DISTANCE_FROM_ORIGIN then
			addMemHighlight(exit, EXIT_COLOR, 0.2)
			totalHighlighted += 1
		end
	end

	if totalHighlighted > 0 then
		memSolverActive = true
		pcall(function()
			game:GetService("StarterGui"):SetCore("SendNotification", {
				Title = "CT",
				Text = totalHighlighted .. " platforms highlighted",
				Duration = 4,
			})
		end)
	else
		warn("[Multy Trials] Memory Solver: No platforms found")
	end
end

