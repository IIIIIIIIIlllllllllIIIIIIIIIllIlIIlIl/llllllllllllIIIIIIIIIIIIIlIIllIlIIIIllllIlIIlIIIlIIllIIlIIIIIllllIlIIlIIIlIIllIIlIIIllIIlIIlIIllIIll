local StarterGui = game:GetService("StarterGui")

local HuntFolder = game.Workspace
    :WaitForChild("Map")
    :WaitForChild("CopeTrialsDirectory")
    :WaitForChild("Hunt")

local copeman = HuntFolder:FindFirstChild("Copeman")

-- Delete Copeman
if copeman then
    copeman:Destroy()
end

-- Notification function
local function notify(text)
    StarterGui:SetCore("SendNotification", {
        Title = "System",
        Text = text,
        Duration = 4
    })
end

-- Initial notification
notify("The Copeman is Eradicated.")

-- Check after 1 second
task.delay(1, function()
    local check = HuntFolder:FindFirstChild("Copeman")

    if not check then
        notify("COPEMAN HAS BEEN OBLITERATED.")
    else
        notify("Warning: Copeman still exists!")
    end
end)
